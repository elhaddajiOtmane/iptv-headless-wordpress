# ==========================================
# .gitignore — iptv-nederland.com
# Headless WordPress + Next.js
# ==========================================

# ----- WordPress Core (never track) -----
/wp-admin/
/wp-includes/
/wp-*.php
!/wp-config.php
/xmlrpc.php
/license.txt
/readme.html
/index.php

# ----- WordPress Content -----
# Ignore everything in wp-content except our custom theme
/wp-content/*
!/wp-content/themes/
/wp-content/themes/*
!/wp-content/themes/headless-iptv/

# ----- Database Dumps -----
/backups/*.sql
/*.sql

# ----- Next.js Frontend -----
/frontend/node_modules/
/frontend/.next/
/frontend/out/
/frontend/.env.local
/frontend/.env.production
/frontend/.vercel/

# ----- Suspicious / Temp Files -----
/default.php
/sanz.PHP
/create_autologin_*.php
/monarx-analyzer.php
*.bak
*.bk
/apeF1xtSc8s25sl21mkGfhL.txt
/seraphinite-accelerator-*.htaccess
/seraph-accel-img-compr-redir.conf
/wordfence-waf.php

# ----- OS & Editor -----
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.vscode/settings.json
.idea/

# ----- Laragon / Local Dev -----
/.private/
/.quarantine/
/.tmb/
/promo/
/skills-lock.json

# ----- Agents -----
/.claude/
# But keep these subdirs tracked
!.claude/skills/
!.claude/tasks.md
!.claude/commands/

# Exclude these from .claude
/.claude/worktrees/
/.claude/write-a-skill/
